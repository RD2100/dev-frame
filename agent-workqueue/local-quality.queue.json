{
  "queue_id": "local-quality-queue",
  "owner": "code-agent",
  "mode": "safe-batch",
  "description": "Default Tier 0 quality queue for code agent. No backend, no destructive ops.",
  "items": [
    {
      "id": "q-local-quality",
      "title": "Run local quality batch (10 checks)",
      "tier": 0,
      "task_file": "scripts/acceptance/examples/batch-local-quality.json",
      "runner": "scripts/acceptance/Run-Batch.ps1",
      "status": "pending",
      "allowed_files": ["runs/powershell-acceptance/**"],
      "forbidden_files": ["src/**", "configs/**", "tasks.yaml", "projects.yaml", "goals/**", ".claude/**", "skills/**"],
      "expected_artifacts": [
        "runs/powershell-acceptance/batch-local-quality/batch-report.md"
      ],
      "escalate_on": ["failed", "missing_artifact", "timeout", "forbidden_command"]
    }
  ]
}
