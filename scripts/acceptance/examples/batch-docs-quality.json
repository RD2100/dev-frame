{
  "batch_id": "batch-docs-quality",
  "mode": "dry-run",
  "description": "Documentation consistency checks. Tier 0.",
  "tasks": [
    {
      "id": "docs-release-pack",
      "title": "Release pack docs present",
      "tier": 0,
      "command": "powershell -Command \"$files=@('docs/v1.17-release-pack.md','docs/OPERATOR_RUNBOOK_INDEX.md','docs/RELEASE_VERIFICATION_CHECKLIST.md','docs/NEXT_AGENT_HANDOFF.md','docs/NEXT_STAGE_BACKLOG.md'); $ok=0; foreach($f in $files){if(Test-Path $f){$ok++}}; if($ok -eq $files.Count){exit 0}else{Write-Host missing:$($files.Count-$ok);exit 1}\"",
      "expected_exit_codes": [0],
      "required_artifacts": [],
      "timeout_seconds": 10
    },
    {
      "id": "docs-recovery",
      "title": "Recovery docs present",
      "tier": 0,
